# Backend API base URL (set to your Railway backend URL in production)
# Example: https://wandernest-server-production.up.railway.app/api/v1
VITE_API_URL=http://localhost:5000/api/v1

# Google reCAPTCHA v3 site key (public key — safe to expose in frontend)
# Get from: https://www.google.com/recaptcha/admin
# Leave empty in development — a mock token will be used automatically
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
